# 数据库配置
DATABASE_URL=mysql+pymysql://username:password@localhost:3306/petct_scheduler
# 或使用 SQLite 进行开发
# DATABASE_URL=sqlite:///./petct_scheduler.db

# JWT 配置
SECRET_KEY=your-secret-key-here-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# 服务配置
API_V1_PREFIX=/api/v1
PROJECT_NAME=PET-CT Scheduler Service
DEBUG=True

# 高风险监控阈值
MAX_CONSECUTIVE_NO_SHOW=3
CHECKIN_TIMEOUT_MINUTES=30
DRUG_WASTE_THRESHOLD=0.15

# 通知配置
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=notification@example.com
SMTP_PASSWORD=your-password
